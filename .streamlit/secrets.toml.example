# Copia questo file in .streamlit/secrets.toml e compila con i tuoi valori
# NON caricare secrets.toml su GitHub!

# Chiave API Anthropic (per il mapping AI)
ANTHROPIC_API_KEY = "sk-ant-..."

# Configurazione email (Gmail consigliato)
# Per Gmail: attiva "App password" in Sicurezza Google Account
SMTP_HOST     = "smtp.gmail.com"
SMTP_PORT     = 587
SMTP_USER     = "la-tua-email@gmail.com"
SMTP_PASSWORD = "xxxx xxxx xxxx xxxx"   # App password Gmail
SMTP_FROM     = "la-tua-email@gmail.com"
ADMIN_EMAIL   = "studiopietroforte@gmail.com"
